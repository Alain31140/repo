<script>

window.addEventListener("load", function () {

  /* =========================
     📅 DATE DU JOUR
  ========================= */
  function majDate() {

    const d = new Date();

    let date = d.toLocaleDateString("fr-FR", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric"
    });

    date = date.charAt(0).toUpperCase() + date.slice(1);

    const zone = document.getElementById("date-fr");
    if (zone) zone.innerHTML = "Nous sommes le " + date;
  }

  /* =========================
     🕒 HEURE EN DIRECT
  ========================= */
  function majHeure() {

    const d = new Date();

    const heure = d.toLocaleTimeString("fr-FR", {
      hour12: false
    });

    const zone = document.getElementById("heure-fr");
    if (zone) zone.innerHTML = "et il est " + heure;
  }

/* =========================
     🕒 SAINT DU JOUR
  ========================= */
function majSaint() {

  const zone = document.getElementById("saint-fr");

  if (!zone) return;

  fetch("https://raw.githubusercontent.com/Alain31140/repo/main/calendar.json")
    .then(response => {
      if (!response.ok) {
        throw new Error("Erreur chargement JSON");
      }
      return response.json();
    })
    .then(data => {

      const now = new Date();

      const jour = String(now.getDate()).padStart(2, "0");
      const mois = String(now.getMonth() + 1).padStart(2, "0");

      const key = jour + "-" + mois;

      const saint = data[key];

      if (saint && saint.label) {

        zone.innerHTML =
          "Aujourd'hui on fête les " + saint.label + "<br>" + "Si c'est ton cas je te souhaite une bonne fête !";

      } else {

        zone.innerHTML = "Saint du jour indisponible";

      }

    })
    .catch(error => {

      console.error("majSaint error:", error);

      zone.innerHTML = "Saint du jour indisponible";

    });

}
/* =========================
     🎉 SAINT SPECIAL
  ========================= */
async function majJourSpecial() {

  const zone = document.getElementById("saint-fr");

  try {

    const d = new Date();

    const key =
      String(d.getDate()).padStart(2, "0") + "-" +
      String(d.getMonth() + 1).padStart(2, "0");

    const res = await fetch("https://Alain31140.github.io/repo/calendar.json");
    const data = await res.json();

    const item = data[key];

    if (!item) {
      zone.innerHTML = "Bonne journée";
      return;
    }

    if (item.type === "saint") {
      zone.innerHTML = "Bonne fête " + item.label;
    }

    if (item.type === "fete") {
      zone.innerHTML = "🎉 " + item.label;
    }

  } catch (e) {
    zone.innerHTML = "Information indisponible";
  }
}

  /* =========================
     📍 LOCALISATION (IP)
  ========================= */
function majPosition() {

  const zone = document.getElementById("position-fr");

  if (!zone) return;

  zone.innerHTML = "Localisation en cours...";

  if (!navigator.geolocation) {

    zone.innerHTML = "GPS non supporté";
    return;
  }

  navigator.geolocation.getCurrentPosition(

    async function(position) {

      const lat = position.coords.latitude;
      const lon = position.coords.longitude;

      try {

        // =========================
        // 🌍 NOM DU LIEU
        // =========================
        const url =
          "https://nominatim.openstreetmap.org/reverse?format=json&lat="
          + lat + "&lon=" + lon;

        const res = await fetch(url);
        const data = await res.json();

        const ville =
          data.address?.city ||
          data.address?.town ||
          data.address?.village ||
          data.address?.hamlet ||
          "Lieu inconnu";

        const route =
          data.address?.road || "";

        const affichage =
          route ? ville + " — " + route : ville;

        // =========================
        // 🔗 GOOGLE MAPS (UNIVERSEL)
        // =========================
        const googleUrl =
          "https://www.google.com/maps/search/?api=1&query="
          + lat + "," + lon;

        // =========================
        // 📍 AFFICHAGE
        // =========================
        zone.innerHTML =
  "📍 Nous nous trouvons à <b>" + affichage + "</b><br><br>" +

  "Latitude : " + lat.toFixed(5) + "<br>" +
  "Longitude : " + lon.toFixed(5) + "<br><br>" +

  "<a href='" + googleUrl + "'>" +
"🗺 Voir ma position réelle</a>"

      }

      catch (e) {

        console.error(e);

        zone.innerHTML =
          "📍 Latitude : "
          + lat.toFixed(5)
          + "<br>Longitude : "
          + lon.toFixed(5);
      }

    },

    function(error) {

      console.error(error);

      zone.innerHTML =
        "Localisation refusée ou indisponible";
    },

    {
      enableHighAccuracy: true,
      timeout: 15000,
      maximumAge: 0
    }

  );
}
  /* =========================
     🚀 INITIALISATION
  ========================= */
  function init() {

    majDate();
    majHeure();
    majSaint();
   /* majJourSpecial();*/
    majPosition();

    // horloge live
    setInterval(majHeure, 1000);
  }

  init();

});

</script>